# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/cryptomind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kraken ────────────────────────────────────────────────────────────────────
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET_KEY=your_kraken_secret_key

# ── Binance WebSocket (prix temps réel) ───────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_RECIPIENT=whatsapp:+33xxxxxxxxx

# ── CoinGecko ─────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=

# ── Trading Configuration ─────────────────────────────────────────────────────
PAPER_TRADING=true
TOTAL_CAPITAL_USD=1000.0
BASE_POSITION_SIZE_PCT=2.0
MAX_POSITION_SIZE_PCT=5.0
STOP_LOSS_PCT=7.0
DRAWDOWN_DISABLE_PCT=12.0
MAX_CONSECUTIVE_LOSSES=3
VOLATILITY_HIGH_THRESHOLD=0.05

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
